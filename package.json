{
  "name": "@plutotcool/fsv",
  "type": "module",
  "version": "0.3.11",
  "packageManager": "pnpm@10.33.1",
  "description": "Fast Scrubbing Video format",
  "license": "MIT",
  "repository": "plutotcool/fsv",
  "homepage": "https://github.com/plutotcool/fsv#readme",
  "bugs": "https://github.com/plutotcool/fsv/issues",
  "author": "Julien Dargelos <julien@plutot.cool>",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "build:demo": "vite build -c demo/vite.config.ts",
    "typecheck": "tsc",
    "lint": "eslint src",
    "release": "changelogen --release --push",
    "dev": "vite -c demo/vite.config.ts",
    "fsv": "tsx src/cli"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "changelogen": "^0.6.2",
    "eslint": "^10.2.1",
    "tsdown": "^0.21.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.8"
  },
  "dependencies": {
    "@napi-rs/webcodecs": "^1.3.1",
    "citty": "^0.2.2",
    "consola": "^3.4.2",
    "node-av": "^5.2.3"
  },
  "peerDependencies": {
    "@types/node": "^25.6.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./cli": {
      "import": "./dist/cli/index.mjs",
      "require": "./dist/cli/index.cjs"
    },
    "./cli/convert": {
      "import": "./dist/cli/convert.mjs",
      "require": "./dist/cli/convert.cjs"
    },
    "./cli/main": {
      "import": "./dist/cli/main.mjs",
      "require": "./dist/cli/main.cjs"
    },
    "./core/Converter": {
      "import": "./dist/core/Converter.mjs",
      "require": "./dist/core/Converter.cjs"
    },
    "./core/Decoder": {
      "import": "./dist/core/Decoder.mjs",
      "require": "./dist/core/Decoder.cjs"
    },
    "./core/Demuxer": {
      "import": "./dist/core/Demuxer.mjs",
      "require": "./dist/core/Demuxer.cjs"
    },
    "./core/FSV": {
      "import": "./dist/core/FSV.mjs",
      "require": "./dist/core/FSV.cjs"
    },
    "./core/Logger": {
      "import": "./dist/core/Logger.mjs",
      "require": "./dist/core/Logger.cjs"
    },
    "./core/Manifest": {
      "import": "./dist/core/Manifest.mjs",
      "require": "./dist/core/Manifest.cjs"
    },
    "./core/Muxer": {
      "import": "./dist/core/Muxer.mjs",
      "require": "./dist/core/Muxer.cjs"
    },
    "./core/Renderer": {
      "import": "./dist/core/Renderer.mjs",
      "require": "./dist/core/Renderer.cjs"
    },
    "./core/TrackDecoder": {
      "import": "./dist/core/TrackDecoder.mjs",
      "require": "./dist/core/TrackDecoder.cjs"
    },
    "./core/Video": {
      "import": "./dist/core/Video.mjs",
      "require": "./dist/core/Video.cjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "fsv": "./dist/cli/index.mjs"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "publishConfig": {
    "access": "public"
  }
}
